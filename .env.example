# === Daily Briefing — Environment Config ===
# Copy to .env and fill in your secrets. Briefing configuration
# goes in brief.yaml. NEVER commit .env.
#
# Only fill in the keys for features you want to use.
# The tool works with zero keys for: weather, news, reddit.

# === Weather (optional — locations are in brief.yaml) ===
# WEATHER_LAT=51.5074
# WEATHER_LON=-0.1278
# WEATHER_NAME=London

# === Google Calendar OAuth ===
# Path to your OAuth token file (default: ~/.google_token.json)
# GOOGLE_TOKEN_PATH=~/.google_token.json
# GOOGLE_CALENDAR_ID=primary

# === GitHub (via gh CLI) ===
# Authenticate first: gh auth login
# No env var needed — gh handles its own token storage.

# === DB Fahrplan — your commute stations ===
# Find station IDs at: https://v6.db.transport.rest/stops
# BAHN_DEPARTURE_STATION=8000105
# BAHN_ARRIVAL_STATION=
# BAHN_TIME=07:30
# BAHN_MODE=depart

# === Reddit (comma-separated subreddits) ===
# REDDIT_SUBREDDITS=programming

# === News RSS feeds (comma-separated URLs) ===
# NEWS_FEEDS=https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml

# === Email (IMAP) — optional, requires app password ===
# EMAIL_IMAP_SERVER=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_USER=
# EMAIL_PASSWORD=

# === Summarizer Providers ===

# Ollama (local LLM)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# === Delivery ===

# ntfy push notification
# NTFY_TOPIC=my-briefing

# === Storage ===
# BRIEFING_DB_PATH=~/.daily_briefing.db
