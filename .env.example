# === Daily Briefing — Environment Config ===
# Copy to .env and fill in your values. Never commit .env.

# GitHub Personal Access Token (classic, with repo + notifications scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Google Calendar — requires gws CLI auth (oauth)
# Run: gws auth login
GOOGLE_CALENDAR_ID=primary

# DB Fahrplan — your commute stations
# Find station IDs at: https://developer.deutschebahn.com/store/apis/info
BAHN_DEPARTURE_STATION=8000105  # Frankfurt Hbf example
BAHN_ARRIVAL_STATION=8000152     # Wiesbaden Hbf example
BAHN_TIME=07:30
BAHN_MODE=depart  # 'depart' or 'arrive'

# Reddit — subreddits to monitor (comma-separated)
REDDIT_SUBREDDITS=programming,de

# News RSS feeds (comma-separated URLs)
NEWS_FEEDS=https://rss.heise.de/heise.rdf,https://dev.to/feed

# Email (IMAP) — optional, requires app password for gmail
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_USER=
EMAIL_PASSWORD=

# Location for weather
WEATHER_LAT=50.1109
WEATHER_LON=8.6821
WEATHER_NAME=Frankfurt
